{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:rasen",
  "type": "Actor",
  "name": "rasen",
  "glyph": "螺旋",
  "purpose": "Public-genetics (公開遺伝) Knowledge Graph mirror — weaves PUBLIC reference genetics (genes / variants / phenotypes / pathways + population-AGGREGATE allele frequencies) across humans, animals, plants and microbes into the kotoba Datom log; surfaces integrated clinical/functional evidence burden over a gene, routed to CARE & RESEARCH, never an individual-genotype registry or discrimination tool.",
  "status": "R1-public-ingest-live",
  "tier": "B",
  "adr": "2606101000",
  "dependsOnAdr": ["2606073000", "2606073800", "2606011000", "2606011500", "2605312345", "2605215000", "2605181100"],
  "schema": ["00-contracts/schemas/genome-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.py emits canonical EAVT",
    "ingest": "methods/ingest.py — PUBLIC reference genetics (MyGene.info + MyVariant.info: Ensembl/NCBI + ClinVar + gnomAD AGGREGATE) → genome-ontology EDN, content-addressed to a kotoba IPFS CIDv1 (raw/sha2-256, matches `ipfs add --cid-version=1 --raw-leaves`); outward-gated (G7)",
    "largeAssets": "DataLad → IPFS (80-data/genome) — reference FASTA/VCF; NO git-lfs",
    "contentAddress": "methods/cid.py — kotoba IPFS CIDv1 raw (ADR-2605231525 / 2606014500 verify.mjs parity)",
    "inference": "Murakumo-only (ADR-2605215000)",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy (analyze/datom/coverage); ingest runs operator/mesh-side, not in-browser WASM"
  },
  "integrates": ["actor:inochi", "actor:mitsuho", "actor:himotoki"],
  "lineage": "molecular-scale sibling of inochi 命 (biosphere, ADR-2606073000); same KG-mirror architecture (edge-primary, aggregate-first, non-adjudicating, mirror-not-target), specialised to the gene/variant scale of public reference genetics",
  "cells": [
    {
      "id": "cell:rasen.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-genome-graph.kotoba.edn",
      "output": ["out/care-report.md"],
      "pipeline": "load-edn → edge-primary integral (gene care-priority = Σ incident variant-association via :located-in + gene-linkage × disclosed clinsig) → locus-burden + pleiotropy + population-aggregate frequency, aggregate-first",
      "doc": "edge-primary clinical/functional evidence concentration; care/research map, never a discrimination tool"
    },
    {
      "id": "cell:rasen.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-genome-graph.kotoba.edn",
      "output": ["out/genome-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (durable) + derived readouts flagged :bond/is-transient (computed on read, N1/G2)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:rasen.coverage",
      "method": "methods/coverage_report.py",
      "input": "data/seed-genome-graph.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "denominator (gene/ClinVar/dbSNP) + inheritance + clinsig + taxon + population-aggregate + pathway-source → gap map",
      "doc": "honest coverage (all-genes ~0 by design); names thin/missing buckets per wave (G5)"
    },
    {
      "id": "cell:rasen.ingest",
      "method": "methods/ingest.py",
      "input": "data/ingest-sources.edn",
      "output": ["out/ingested-genome-graph.kotoba.edn", "out/ingested-genome-datoms.kotoba.edn", "out/ingested.cid", "out/ingest-provenance.json"],
      "pipeline": "read bounded public allowlist → fetch MyGene.info (gene→Ensembl+cytoband+GO.BP+UniProt) + MyVariant.info (rsID→ClinVar significance + gnomAD super-population AGGREGATE freq) + Reactome (UniProt→curated pathways) → normalise to genome-ontology EDN (GO + Reactome :participates-in, deduped/best-evidence/capped, G5) → datom_emit → content-address (CIDv1 raw) + best-effort ipfs pin → provenance manifest",
      "doc": "OUTWARD-GATED (G7) public-reference ingest; PUBLIC/aggregate only, no individual genotypes (G1); kotoba IPFS content-addressed (verifiable without ipfs daemon)",
      "gated": "G7 — Council + operator DID for scope expansion beyond the committed bounded slice"
    },
    {
      "id": "cell:rasen.publish",
      "method": "methods/publish.py",
      "input": ["out/ingested-genome-graph.kotoba.edn", "out/ingested-genome-datoms.kotoba.edn"],
      "output": ["80-data/genome/genome-graph.kotoba.edn", "80-data/genome/genome-datoms.kotoba.edn", "80-data/genome/PUBLISH.md", "80-data/genome/publish-manifest.json"],
      "pipeline": "pin artifacts (assert daemon CID == cid.py CID) → IPNS self-key publish (stable /ipns/<id> → latest graph) → snapshot graph+datoms+provenance+manifest into 80-data/genome (git-tracked, no git-lfs G8)",
      "doc": "OUTWARD-GATED (G7) publish to public IPFS; PUBLIC reference only, safe by construction (G1); Pinata/public-pin services are an operator API-key add-on",
      "gated": "G7 — operator/mesh-side"
    }
  ],
  "wasm": {
    "status": "build-ready",
    "world": "etzhayyim:rasen/rasen-actor@0.1.0",
    "wit": "wasm/wit/world.wit",
    "entry": "wasm/app.py",
    "exports": ["analyze", "datoms", "coverage"],
    "build": "wasm/build.sh (componentize-py → CID → DID-doc EtzhayyimWasmComponent service; ADR-2606014500/2606014600)",
    "note": "export bodies runnable in dev + CI-covered (tests/test_wasm.py); the componentize-py build is the operator step; G1 holds in WASM (embeds bounded PUBLIC seed only)"
  },
  "gates": {
    "G1": "CARE / RESEARCH map, NEVER an individual-genotype registry or discrimination tool — no individual genotypes / sample / family sequence; the unit is gene/variant/population-aggregate; allele frequencies are super-population aggregate only; chromosomal location is coarse (cytoband); the routing is care, research and equity, never insurance / employment / eugenic / forensic targeting",
    "G2": "edge-primary (N1) — evidence/burden lives only on :en/grasping-load × disclosed :en/clinsig; gene care-priority is the integral computed on read; no :genome/score-of-gene",
    "G3": "non-adjudicating (N3) — clinical-significance categories are DISCLOSED curated facts (ClinVar/OMIM/GWAS-Catalog), never rasen verdicts; rasen never diagnoses, never rates a person",
    "G4": "public venue — open-source + on-chain + 1 SBT = 1 vote; PUBLIC reference data only; never a private/covert registry",
    "G5": "sourcing honesty — every record :authoritative | :representative; coverage of all genes/variants ~0 by design; no fabricated coverage",
    "G6": "Murakumo-only narration (ADR-2605215000)",
    "G7": "outward-gated — live ingest (ClinVar/gnomAD/Ensembl/GWAS-Catalog APIs) requires Council + operator DID; R0 = analyzer + schema + seed only",
    "G8": "no git-lfs — large reference assets (FASTA/VCF) via DataLad → IPFS (80-data/genome)"
  }
}
